{
  "name": "pz-mod-porter-web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Vite + React frontend for the PZ Build 41 -> 42 mod converter (100% client-side).",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b --noEmit"
  },
  "dependencies": {
    "diff": "^7.0.0",
    "jszip": "^3.10.1",
    "lucide-react": "^0.460.0",
    "luaparse": "^0.3.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/diff": "^7.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "^6.0.3",
    "vite": "^6.0.0"
  },
  "allowScripts": {
    "esbuild@0.25.12": true
  }
}
