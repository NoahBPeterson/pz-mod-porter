{
  "name": "pz-b41-to-b42-converter",
  "version": "0.1.0",
  "description": "Convert Project Zomboid Build 41 workshop mods to Build 42 (web, client-side).",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "tsc && node dist/test/run.js",
    "serve": "python3 -m http.server 8731",
    "convert": "tsc && node dist/cli.js"
  },
  "license": "MIT",
  "devDependencies": {
    "@types/luaparse": "^0.2.13",
    "@types/node": "^26.0.0",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "luaparse": "^0.3.1"
  }
}
